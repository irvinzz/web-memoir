{
  "name": "web-memoir",
  "version": "1.0.0",
  "description": "An Electron application with React and TypeScript",
  "main": "./out/main/index.js",
  "author": "example.com",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps && bash scripts/postinstall.sh",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux"
  },
  "dependencies": {
    "@aws-sdk/credential-providers": "^3.1014.0",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@playwright/browser-chromium": "^1.58.2",
    "agentkeepalive": "^4.6.0",
    "crawlee": "^3.16.0",
    "electron-updater": "^6.8.3",
    "get-port": "^7.2.0",
    "iconv-lite": "^0.7.2",
    "mongodb": "^7.1.0",
    "node-forge": "^1.3.3",
    "playwright": "^1.58.2",
    "tar": "^7.5.12"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@emotion/styled": "^11.14.1",
    "@mongodb-js/mongodb-downloader": "^1.1.8",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "mkdirp": "^3.0.1",
    "open": "^11.0.0",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.9.3",
    "vite": "^7.0.0",
    "wait-port": "^1.1.0"
  },
  "overrides": {
    "@mongodb-js/mongodb-downloader": {
      "tar": ">7.5.7"
    }
  }
}
